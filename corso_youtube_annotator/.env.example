# Optional: override defaults from annotate_videos.py config block
OLLAMA_HOST=http://localhost:11434
LOCAL_MODEL_NAME=qwen2.5vl:7b

# Required for most age-restricted surgery videos (export while logged into YouTube in that browser).
# Pick ONE of:
# YTDLP_COOKIES=/absolute/path/to/cookies.txt
# YTDLP_COOKIES_FROM_BROWSER=chrome
# YTDLP_COOKIES_FROM_BROWSER=safari
# YTDLP_COOKIES_FROM_BROWSER=firefox

# Default helps with YouTube "no formats" / SABR. Set empty to turn off:
# YTDLP_EXTRACTOR_ARGS=youtube:player_client=web,default

# Optional timeouts (seconds)
# YTDLP_METADATA_TIMEOUT=400
# YTDLP_TRANSCRIPT_TIMEOUT=320

# Vision: fraction of file frame count to analyze (~10%). Set MAX_FRAMES_PER_VIDEO to cap cost.
# FRAME_SAMPLE_RATE=0.1
# MAX_FRAMES_PER_VIDEO=0

# Recreate draft xlsx from INPUT_XLSX (delete old draft first). Use once when starting clean.
# RESET_DRAFT_WORKBOOK=true

# Process from Excel row N upward (1-based sheet row; use to try a different video in the sheet).
# START_EXCEL_ROW=50
# MAX_ROWS_PER_RUN=1
